/** 
 * 全局样式 - 戒瘾打卡
 * 暖橙治愈系风格
 */

/* ===== CSS Variables ===== */
page {
  --primary: #FF6B35;
  --primary-light: #FF8F5E;
  --primary-dark: #E55A2B;
  --secondary: #FFB347;
  --accent: #FFD166;
  --success: #06D6A0;
  --warning: #FFD166;
  --danger: #EF476F;
  --bg: #FFF7F0;
  --bg-card: #FFFFFF;
  --bg-card-2: #FFF0E6;
  --text-primary: #2D2D2D;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #F0E0D0;
  --shadow: 0 2px 12px rgba(255, 107, 53, 0.1);
  --shadow-lg: 0 4px 24px rgba(255, 107, 53, 0.15);
  --radius: 12px;
  --radius-lg: 20px;
  --radius-full: 50%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ===== Reset ===== */
view, text, image, button, input, textarea {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ===== Common Components ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: var(--shadow);
}

.card-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius);
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: var(--shadow);
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius);
  border: none;
  box-shadow: 0 4px 16px rgba(255, 107, 53, 0.4);
  transition: all 0.3s;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2px 8px rgba(255, 107, 53, 0.3);
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  background: var(--bg-card-2);
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius);
  border: 2rpx solid var(--primary);
}

.btn-small {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: #fff;
  font-size: 24rpx;
  border-radius: 40rpx;
  border: none;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 30rpx 30rpx 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 0 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 20rpx 30rpx;
}

/* ===== Animations ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes slideUp {
  from { transform: translateY(60px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.4s ease-out;
}

.scale-in {
  animation: scaleIn 0.3s ease-out;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--text-light);
  text-align: center;
}

/* ===== Safe Area ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
