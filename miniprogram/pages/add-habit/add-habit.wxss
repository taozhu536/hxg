/* ===== 添加习惯页面 ===== */

.page {
  min-height: 100vh;
  background: #FFF7F0;
}

.form {
  padding: 30rpx;
  height: 100vh;
}

.form-section {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #F0E0D0;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF6B35;
}

/* ===== 分类选择 ===== */
.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 24rpx 16rpx;
  border-radius: 14rpx;
  border: 2rpx solid #F0E0D0;
  transition: all 0.2s;
  gap: 8rpx;
}

.category-item.active {
  border-color: #FF6B35;
  background: #FFF0E6;
}

.cat-icon {
  font-size: 40rpx;
}

.cat-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
}

.category-item.active .cat-name {
  color: #FF6B35;
}

/* ===== 图标选择 ===== */
.icon-selector {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  border: 2rpx solid #F0E0D0;
}

.selected-icon {
  font-size: 56rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF0E6;
  border-radius: 14rpx;
}

.icon-change-hint {
  font-size: 26rpx;
  color: #FF6B35;
}

/* ===== 图标选择弹窗 ===== */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.popup-overlay.show {
  opacity: 1;
  visibility: visible;
}

.icon-picker-panel {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #999;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.icon-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  font-size: 40rpx;
  background: #F8F8F8;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.icon-item.active {
  border-color: #FF6B35;
  background: #FFF0E6;
}

.icon-item:active {
  transform: scale(0.9);
}

/* ===== 提交按钮 ===== */
.form-actions {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}
