<!-- 设置页面 -->
<view class="page">
  
  <view class="settings-group">
    <text class="group-title">⏰ 打卡提醒</text>
    
    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-label">每日提醒</text>
        <text class="setting-desc">到时间提醒你打卡</text>
      </view>
      <switch checked="{{reminderEnabled}}" bindchange="onReminderSwitch" color="#FF6B35" />
    </view>

    <view class="setting-item" wx:if="{{reminderEnabled}}" bindtap="onShowTimePicker">
      <view class="setting-info">
        <text class="setting-label">提醒时间</text>
      </view>
      <view class="setting-value">
        <text>{{reminderTime}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="settings-group">
    <text class="group-title">ℹ️ 其他</text>
    
    <view class="setting-item" bindtap="onAbout">
      <view class="setting-info">
        <text class="setting-label">关于戒瘾打卡</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="setting-item" bindtap="onClearData">
      <view class="setting-info">
        <text class="setting-label">清除本地数据</text>
        <text class="setting-desc">仅清除本地设置，不影响云端</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 时间选择器 -->
  <picker mode="time" value="{{reminderTime}}" bindchange="onTimeChange" wx:if="{{showTimePicker}}"></picker>

</view>
