<!-- 个人中心页面 -->
<view class="page">

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:if="{{!loading}}">

    <!-- 用户信息区 -->
    <view class="profile-header">
      <block wx:if="{{userInfo.avatarUrl}}">
        <image class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      </block>
      <block wx:else>
        <view class="avatar">👤</view>
      </block>
      <text class="nickname">{{userInfo.nickName || '戒瘾勇士'}}</text>
      <text class="motto">每一次打卡，都是向更好的自己迈进 💪</text>
      <button class="edit-profile-btn" wx:if="{{!gotUserProfile}}" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
        🖊️ 获取微信头像昵称
      </button>
    </view>

    <!-- 总览数据 -->
    <view class="overview-cards" wx:if="{{overview}}">
      <view class="overview-card">
        <text class="overview-num">{{overview.activeHabits || 0}}</text>
        <text class="overview-label">活跃习惯数</text>
      </view>
      <view class="overview-card">
        <text class="overview-num">{{overview.totalCheckins || 0}}</text>
        <text class="overview-label">累计打卡</text>
      </view>
      <view class="overview-card">
        <text class="overview-num">{{overview.monthlyCheckins || 0}}</text>
        <text class="overview-label">本月打卡</text>
      </view>
    </view>

    <!-- 最佳习惯 -->
    <view class="section" wx:if="{{overview && overview.topHabits && overview.topHabits.length > 0}}">
      <text class="section-title">🏆 最佳习惯</text>
      <view class="top-habit-item" wx:for="{{overview.topHabits}}" wx:key="_id"
            bindtap="onHabitTap" data-id="{{item._id}}">
        <text class="top-icon">{{item.icon}}</text>
        <view class="top-info">
          <text class="top-name">{{item.name}}</text>
          <text class="top-stats">累计 {{item.totalDays}} 天 · 连胜 {{item.streak}} 天</text>
        </view>
        <text class="top-arrow">›</text>
      </view>
    </view>

    <!-- 好友区域 -->
    <view class="section">
      <view class="section-title-row">
        <text class="section-title">👥 我的好友</text>
        <view class="section-action" bindtap="onShowAddFriend">+ 添加</view>
      </view>

      <view wx:if="{{friends && friends.length > 0}}">
        <view class="friend-item" wx:for="{{friends}}" wx:key="openid">
          <block wx:if="{{item.avatarUrl}}">
            <image class="friend-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <block wx:else>
            <view class="friend-avatar-placeholder">👤</view>
          </block>
          <view class="friend-info">
            <text class="friend-name">{{item.nickName || '好友'}}</text>
            <text class="friend-stats">今日打卡 {{item.todayCheckins}} 次 · 累计 {{item.totalCheckins}} 次</text>
          </view>
        </view>
      </view>
      <view wx:else>
        <view class="friend-empty">
          <text>还没有好友，点击右上角「+ 添加」吧</text>
        </view>
      </view>
    </view>

    <!-- 邀请码 -->
    <view class="invite-card">
      <text class="invite-label">📢 我的邀请码</text>
      <text class="invite-code">{{inviteCode || '---'}}</text>
      <text class="invite-hint">分享给朋友，让对方输入此码即可添加好友</text>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-label">关于戒瘾打卡</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

  </view>

  <!-- 添加好友弹窗 -->
  <view class="add-friend-overlay {{showAddFriend ? 'show' : ''}}" catchtap="onCloseAddFriend">
    <view class="add-friend-content" catchtap="">
      <view class="add-friend-header">
        <text class="add-friend-title">🤝 添加好友</text>
        <view class="add-friend-close" bindtap="onCloseAddFriend">✕</view>
      </view>
      <view class="add-friend-body">
        <text class="add-friend-label">输入对方的邀请码</text>
        <input class="add-friend-input" placeholder="例如：2P31" 
               value="{{addFriendCode}}" bindinput="onAddCodeInput" maxlength="4" />
        <button class="btn-primary" bindtap="onConfirmAddFriend" wx:if="{{addFriendCode.length >= 4}}">✅ 确认添加</button>
        <button class="btn-disabled" wx:else>输入4位邀请码</button>
      </view>
    </view>
  </view>

</view>
