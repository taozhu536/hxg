/* ===== 个人中心样式 ===== */

.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* ===== 用户信息区 ===== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #FF6B35, #FFB347);
  border-radius: 0 0 40rpx 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.motto {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 概览卡片 ===== */
.overview-cards {
  display: flex;
  gap: 16rpx;
  margin: -20rpx 24rpx 24rpx;
  position: relative;
  z-index: 2;
}

.overview-card {
  flex: 1;
  background: #fff;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.overview-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF6B35;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
}

/* ===== 最佳习惯 ===== */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.top-habit-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 14rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}

.top-habit-item:active {
  transform: scale(0.98);
}

.top-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF0E6;
  border-radius: 14rpx;
  margin-right: 16rpx;
}

.top-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.top-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.top-stats {
  font-size: 22rpx;
  color: #999;
}

.top-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 菜单 ===== */
.menu-group {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #2D2D2D;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 加载 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  gap: 20rpx;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FFF0E6;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
