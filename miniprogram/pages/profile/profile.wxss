/* ===== 个人中心样式 ===== */

.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* ===== 用户信息区 ===== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #FF6B35, #FFB347);
  border-radius: 0 0 40rpx 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.4);
}

.edit-profile-btn {
  margin-top: 16rpx;
  padding: 8rpx 28rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.4);
  border-radius: 30rpx;
  line-height: 2;
}

.edit-profile-btn::after {
  border: none;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.motto {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 概览卡片 ===== */
.overview-cards {
  display: flex;
  gap: 16rpx;
  margin: -20rpx 24rpx 24rpx;
  position: relative;
  z-index: 2;
}

.overview-card {
  flex: 1;
  background: #fff;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.overview-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF6B35;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
}

/* ===== 最佳习惯 ===== */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.top-habit-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 14rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}

.top-habit-item:active {
  transform: scale(0.98);
}

.top-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF0E6;
  border-radius: 14rpx;
  margin-right: 16rpx;
}

.top-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.top-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.top-stats {
  font-size: 22rpx;
  color: #999;
}

.top-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 好友区域 ===== */
.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-action {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: #FFF0E6;
  border-radius: 24rpx;
}

.section-action:active {
  opacity: 0.7;
}

.friend-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.friend-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #FFF0E6;
  border-radius: 50%;
  margin-right: 16rpx;
}

.friend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.friend-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.friend-stats {
  font-size: 22rpx;
  color: #999;
}

.friend-empty {
  text-align: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* ===== 邀请码卡片 ===== */
.invite-card {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF0E6, #FFF8F0);
  border-radius: 16rpx;
  border: 2rpx solid #FFE0CC;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.invite-label {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
}

.invite-code {
  font-size: 56rpx;
  font-weight: 800;
  color: #FF6B35;
  letter-spacing: 12rpx;
}

.invite-hint {
  font-size: 22rpx;
  color: #999;
}

/* ===== 添加好友弹窗 ===== */
.add-friend-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.add-friend-overlay.show {
  opacity: 1;
  visibility: visible;
}

.add-friend-content {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.add-friend-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 0;
}

.add-friend-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.add-friend-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  background: #F5F5F5;
  border-radius: 50%;
}

.add-friend-body {
  padding: 30rpx;
}

.add-friend-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.add-friend-input {
  width: 100%;
  height: 90rpx;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
  text-align: center;
  letter-spacing: 12rpx;
  margin-bottom: 24rpx;
}

.add-friend-body .btn-primary {
  width: 100%;
  background: #FF6B35;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.add-friend-body .btn-disabled {
  width: 100%;
  background: #F0F0F0;
  color: #ccc;
  border: none;
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 菜单 ===== */
.menu-group {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #2D2D2D;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 加载 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  gap: 20rpx;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FFF0E6;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
